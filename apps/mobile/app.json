{
  "expo": {
    "name": "LatchClub",
    "slug": "latchclub",
    "scheme": "latchclub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F1A22"
    },
    "ios": {
      "supportsTablet": true,
      "usesAppleSignIn": true,
      "bundleIdentifier": "ca.latchclub.mobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-apple-authentication",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "LatchClub uses Face ID to confirm coupon redemption."
        }
      ]
    ]
  }
}
