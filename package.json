{
  "name": "latchclub",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:status": "supabase status",
    "db:reset": "supabase db reset",
    "db:push": "supabase db push",
    "db:push:dry": "supabase db push --dry-run",
    "db:migration:new": "supabase migration new",
    "db:types": "supabase gen types typescript --linked > packages/db/src/database.types.ts"
  },
  "devDependencies": {
    "supabase": "^2.84.4",
    "turbo": "^2.5.6",
    "typescript": "^5.8.3"
  }
}
